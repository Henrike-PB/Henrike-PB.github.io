---
import '@/styles/global.css';
import { personal } from '@/data/personal';
import { ui } from '@/i18n/ui';
import {
  DEFAULT_LOCALE,
  htmlLang,
  localePath,
  ogLocale,
  LOCALES,
  type Locale,
} from '@/lib/i18n';

type Props = {
  title?: string;
  description?: string;
  image?: string;
  locale?: Locale;
};

const {
  title = ui.meta.title[DEFAULT_LOCALE],
  description = ui.meta.description[DEFAULT_LOCALE],
  image = '/og-image.jpg',
  locale = DEFAULT_LOCALE,
} = Astro.props;

const resolvedTitle = title;
const resolvedDescription = description;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site).toString();
const portraitImage = new URL('/profile.jpg', Astro.site).toString();

const homeForLocale = (l: Locale) => new URL(localePath('/', l), Astro.site).toString();

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${homeForLocale(DEFAULT_LOCALE)}#henrike`,
  name: personal.name,
  alternateName: [personal.shortName, 'Henrike Braga'],
  givenName: 'Henrike',
  familyName: 'Pajares Braga',
  url: homeForLocale(DEFAULT_LOCALE),
  image: portraitImage,
  jobTitle: personal.jobTitle[locale],
  description: resolvedDescription,
  worksFor: { '@type': 'Organization', name: 'Appmax', url: 'https://appmax.com.br' },
  birthDate: personal.birthDate.slice(0, 10),
  birthPlace: { '@type': 'Place', name: 'Porto Alegre, RS, Brasil' },
  nationality: { '@type': 'Country', name: 'Brasil' },
  knowsLanguage: ['Portuguese', 'English'],
  email: `mailto:${personal.contacts.email}`,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Porto Alegre',
    addressRegion: 'RS',
    addressCountry: 'BR',
  },
  knowsAbout: [
    'Data Engineering',
    'Python',
    'PySpark',
    'Apache Airflow',
    'AWS',
    'Amazon Redshift',
    'DynamoDB',
    'FastAPI',
    'ETL',
    'SQL',
  ],
  alumniOf: [
    { '@type': 'EducationalOrganization', name: 'UNISINOS' },
    { '@type': 'EducationalOrganization', name: 'Instituto da Oportunidade Social' },
    { '@type': 'EducationalOrganization', name: 'Geração Caldeira' },
  ],
  sameAs: [
    personal.contacts.linkedin,
    personal.contacts.github,
    personal.contacts.instagram,
    personal.contacts.photographyPortfolio,
  ],
};

const profilePageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  url: canonicalURL.toString(),
  name: `${personal.name} · Portfolio`,
  description: resolvedDescription,
  inLanguage: htmlLang(locale),
  mainEntity: { '@id': `${homeForLocale(DEFAULT_LOCALE)}#henrike` },
  about: { '@id': `${homeForLocale(DEFAULT_LOCALE)}#henrike` },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  url: homeForLocale(DEFAULT_LOCALE),
  name: `${personal.name} · Portfolio`,
  inLanguage: htmlLang(locale),
  author: { '@type': 'Person', name: personal.name },
};
---

<!doctype html>
<html lang={htmlLang(locale)}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {
      /* CSP de defesa em profundidade — só em prod (em dev quebraria o HMR do Vite).
         GitHub Pages não permite headers, então vai via <meta>; frame-ancestors/XFO
         não funcionam por meta (sem proteção a clickjacking por aqui). */
    }
    {
      import.meta.env.PROD && (
        <meta
          http-equiv="Content-Security-Policy"
          content="default-src 'self'; base-uri 'self'; object-src 'none'; frame-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://formsubmit.co; form-action 'self' https://formsubmit.co; upgrade-insecure-requests"
        />
      )
    }
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="tY7-pwTszIPMR5z2MVAoHn3RXoAFXIz2v8P4Yt0ceXM" />
    <link rel="canonical" href={canonicalURL} />

    {
      LOCALES.map((l) => (
        <link rel="alternate" hreflang={htmlLang(l)} href={homeForLocale(l)} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={homeForLocale(DEFAULT_LOCALE)} />

    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <meta name="author" content={personal.name} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="bingbot" content="index, follow" />
    <meta name="theme-color" content="#06142e" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f5d7db" media="(prefers-color-scheme: light)" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="geo.region" content="BR-RS" />
    <meta name="geo.placename" content="Porto Alegre" />

    <meta property="og:type" content="profile" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ui.meta.ogImageAlt[locale]} />
    <meta property="og:locale" content={ogLocale(locale)} />
    {
      LOCALES.filter((l) => l !== locale).map((l) => (
        <meta property="og:locale:alternate" content={ogLocale(l)} />
      ))
    }
    <meta property="og:site_name" content={`${personal.name} · Portfolio`} />
    <meta property="profile:first_name" content="Henrike" />
    <meta property="profile:last_name" content="Pajares Braga" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ui.meta.ogImageAlt[locale]} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(profilePageSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
    />

    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const isDark = stored ? stored === 'dark' : prefersDark;
          if (isDark) document.documentElement.classList.add('dark');
        } catch (_) {}
      })();
    </script>
  </head>

  <body>
    <a href="#main" class="skip-link">{ui.meta.skipToContent[locale]}</a>

    <slot />

    <script>
      import { computeAge, currentYear } from '@/lib/age';
      import { personal } from '@/data/personal';

      document.querySelectorAll('[data-age]').forEach((el) => {
        el.textContent = String(computeAge(personal.birthDate));
      });
      document.querySelectorAll('[data-current-year]').forEach((el) => {
        el.textContent = String(currentYear());
      });
    </script>
  </body>
</html>
