---
import '@/styles/global.css';
import { personal } from '@/data/personal';

type Props = {
  title?: string;
  description?: string;
  image?: string;
};

const {
  title = `${personal.name} · Engenheiro de Dados | Python, AWS, Airflow`,
  description = 'Portfólio oficial de Henrike Pajares Braga, Engenheiro de Dados em Porto Alegre. Construo pipelines de ETL com PySpark, Airflow e AWS, APIs em FastAPI e modelagem em Redshift e DynamoDB.',
  image = '/og-image.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site).toString();

const keywords = [
  'Henrike Pajares Braga',
  'Henrike Braga',
  'Henrike PB',
  'Engenheiro de Dados Porto Alegre',
  'Data Engineer Brasil',
  'PySpark',
  'Airflow',
  'AWS',
  'FastAPI',
  'Python',
  'Appmax',
  'portfólio desenvolvedor',
];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: personal.name,
  alternateName: [personal.shortName, 'Henrike Braga'],
  givenName: 'Henrike',
  familyName: 'Pajares Braga',
  url: canonicalURL.toString(),
  image: ogImage,
  jobTitle: 'Engenheiro de Dados',
  description,
  worksFor: { '@type': 'Organization', name: 'Appmax' },
  birthDate: personal.birthDate.slice(0, 10),
  birthPlace: { '@type': 'Place', name: 'Porto Alegre, RS, Brasil' },
  email: `mailto:${personal.contacts.email}`,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Porto Alegre',
    addressRegion: 'RS',
    addressCountry: 'BR',
  },
  knowsAbout: [
    'Engenharia de Dados',
    'Python',
    'PySpark',
    'Apache Airflow',
    'AWS',
    'Amazon Redshift',
    'DynamoDB',
    'FastAPI',
    'ETL',
    'SQL',
  ],
  alumniOf: [
    { '@type': 'EducationalOrganization', name: 'UNISINOS' },
    { '@type': 'EducationalOrganization', name: 'Instituto da Oportunidade Social' },
    { '@type': 'EducationalOrganization', name: 'Geração Caldeira' },
  ],
  sameAs: [
    personal.contacts.linkedin,
    personal.contacts.github,
    personal.contacts.instagram,
    personal.contacts.photographyPortfolio,
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  url: canonicalURL.toString(),
  name: `${personal.name} · Portfólio`,
  inLanguage: 'pt-BR',
  author: { '@type': 'Person', name: personal.name },
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(', ')} />
    <meta name="author" content={personal.name} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="bingbot" content="index, follow" />
    <meta name="theme-color" content="#06142e" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f5d7db" media="(prefers-color-scheme: light)" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="geo.region" content="BR-RS" />
    <meta name="geo.placename" content="Porto Alegre" />

    <meta property="og:type" content="profile" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`Foto de ${personal.name}, Engenheiro de Dados`} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content={`${personal.name} · Portfólio`} />
    <meta property="profile:first_name" content="Henrike" />
    <meta property="profile:last_name" content="Pajares Braga" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`Foto de ${personal.name}`} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
    />

    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const isDark = stored ? stored === 'dark' : prefersDark;
          if (isDark) document.documentElement.classList.add('dark');
        } catch (_) {}
      })();
    </script>
  </head>

  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:p-2 focus:bg-[var(--bg-card)] focus:text-[var(--fg)] focus:border focus:border-[var(--border-strong)] focus:rounded">
      Pular para o conteúdo
    </a>

    <slot />

    <script is:inline>
      (function () {
        const BIRTH = '2001-09-01T16:00:00-03:00';
        function age() {
          const now = new Date();
          const birth = new Date(BIRTH);
          let a = now.getFullYear() - birth.getFullYear();
          const m = now.getMonth() - birth.getMonth();
          if (m < 0 || (m === 0 && now.getDate() < birth.getDate())) a -= 1;
          return a;
        }
        document.querySelectorAll('[data-age]').forEach((el) => {
          el.textContent = String(age());
        });
        document.querySelectorAll('[data-current-year]').forEach((el) => {
          el.textContent = String(new Date().getFullYear());
        });
      })();
    </script>
  </body>
</html>
