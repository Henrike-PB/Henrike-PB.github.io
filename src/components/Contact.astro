---
import { Icon } from 'astro-icon/components';
import { personal } from '@/data/personal';
---

<section id="contato" class="section">
  <div class="container-page">
    <div class="contact-header">
      <span class="section-eyebrow">Contato</span>
      <h2 class="heading-section">
        Vamos <span class="accent">conversar</span>?
      </h2>
      <p class="contact-intro">
        Aberto a oportunidades, parcerias e conversas sobre tecnologia. Respondo o quanto antes.
      </p>
    </div>

    <div class="contact-grid">
      <aside class="contact-aside">
        <a href={`mailto:${personal.contacts.email}`} class="contact-direct">
          <Icon name="lucide:mail" />
          <div>
            <span>Email</span>
            <strong>{personal.contacts.email}</strong>
          </div>
        </a>
        <a href={personal.contacts.linkedin} target="_blank" rel="noopener" class="contact-direct">
          <Icon name="simple-icons:linkedin" />
          <div>
            <span>LinkedIn</span>
            <strong>/in/henrikebraga</strong>
          </div>
        </a>
        <a href={personal.contacts.github} target="_blank" rel="noopener" class="contact-direct">
          <Icon name="simple-icons:github" />
          <div>
            <span>GitHub</span>
            <strong>@Henrike-PB</strong>
          </div>
        </a>
      </aside>

      <form
        id="contact-form"
        class="contact-form"
        action={personal.formSubmitEndpoint}
        method="POST"
        novalidate
      >
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_subject" value="Contato via portfólio" />

        <div class="field">
          <label for="contact-name">Nome</label>
          <input
            id="contact-name"
            name="name"
            type="text"
            placeholder="Como posso te chamar?"
            required
            autocomplete="name"
          />
        </div>

        <div class="field">
          <label for="contact-email">Email</label>
          <input
            id="contact-email"
            name="email"
            type="email"
            placeholder="seu@email.com"
            required
            autocomplete="email"
          />
        </div>

        <div class="field">
          <label for="contact-message">Mensagem</label>
          <textarea
            id="contact-message"
            name="message"
            rows="5"
            placeholder="Conta o que você gostaria de propor ou perguntar..."
            required
          ></textarea>
        </div>

        <button type="submit" class="btn btn-primary contact-submit">
          <Icon name="lucide:send" />
          Enviar mensagem
        </button>

        <p class="form-status" data-form-status aria-live="polite"></p>
      </form>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const form = document.getElementById('contact-form');
    const status = document.querySelector('[data-form-status]');
    if (!form || !status) return;

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const submit = form.querySelector('button[type="submit"]');
      submit.setAttribute('disabled', 'true');
      status.textContent = 'Enviando...';
      status.dataset.kind = 'pending';

      try {
        const data = new FormData(form);
        const res = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });
        if (!res.ok) throw new Error('Falha no envio');
        form.reset();
        status.textContent = 'Mensagem enviada! Te respondo assim que possível.';
        status.dataset.kind = 'ok';
      } catch (err) {
        status.textContent = 'Algo deu errado. Tente de novo ou me chame por email.';
        status.dataset.kind = 'error';
      } finally {
        submit.removeAttribute('disabled');
      }
    });
  })();
</script>

<style>
  .contact-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .contact-intro {
    color: var(--fg-muted);
    margin: 1rem auto 0;
    max-width: 38rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 900px) {
    .contact-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
      gap: 2.5rem;
    }
  }

  .contact-aside {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .contact-direct {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .contact-direct:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .contact-direct [data-icon] {
    width: 1.4rem;
    height: 1.4rem;
    color: var(--accent);
    flex-shrink: 0;
  }
  .contact-direct span {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-subtle);
    display: block;
  }
  .contact-direct strong {
    color: var(--fg);
    font-weight: 600;
    font-size: 0.95rem;
    word-break: break-all;
  }

  .contact-form {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: clamp(1.25rem, 3vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .field label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--fg);
  }
  .field input,
  .field textarea {
    width: 100%;
    padding: 0.7rem 0.9rem;
    font: inherit;
    font-size: 0.95rem;
    background: var(--bg);
    color: var(--fg);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-md);
    transition: border-color 0.2s, box-shadow 0.2s;
    resize: vertical;
  }
  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--fg-subtle);
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--ring);
  }
  .field textarea {
    min-height: 8rem;
  }

  .contact-submit {
    align-self: flex-start;
  }
  .contact-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-status {
    margin: 0;
    font-size: 0.9rem;
    min-height: 1.25em;
  }
  .form-status[data-kind='pending'] {
    color: var(--fg-muted);
  }
  .form-status[data-kind='ok'] {
    color: #16a34a;
  }
  .form-status[data-kind='error'] {
    color: #dc2626;
  }
</style>
