---
import { Icon } from 'astro-icon/components';
import { ui } from '@/i18n/ui';
import type { Locale } from '@/lib/i18n';
import { DEFAULT_LOCALE, localePath, otherLocale } from '@/lib/i18n';

interface Props {
  locale?: Locale;
}

const { locale = DEFAULT_LOCALE } = Astro.props;

const home = localePath('/', locale);

const navItems = [
  { href: `${home}#sobre`, label: ui.header.nav.about[locale] },
  { href: `${home}#experiencia`, label: ui.header.nav.experience[locale] },
  { href: `${home}#stack`, label: ui.header.nav.stack[locale] },
  { href: `${home}#projetos`, label: ui.header.nav.projects[locale] },
  { href: `${home}#voluntariado`, label: ui.header.nav.volunteer[locale] },
  { href: `${home}#educacao`, label: ui.header.nav.education[locale] },
  { href: `${home}#contato`, label: ui.header.nav.contact[locale] },
];

const other = otherLocale(locale);
const otherHome = localePath('/', other);
const otherLabel = other === 'en' ? 'EN' : 'PT';
---

<header class="site-header">
  <div class="container-page header-inner">
    <a href={`${home}#hero`} class="brand">
      <span class="brand-mark brand-mark--sm">HPB</span>
      <span class="sr-only">— {ui.header.backToTop[locale]}</span>
    </a>

    <nav class="nav-desktop" aria-label={ui.header.primaryNav[locale]}>
      <ul>
        {
          navItems.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header-actions">
      <a
        href={otherHome}
        class="lang-switch"
        hreflang={other === 'en' ? 'en' : 'pt-BR'}
        data-lang-switch
      >
        <Icon name="lucide:globe" aria-hidden="true" />
        <span>{otherLabel}</span>
        <span class="sr-only">— {ui.header.switchLanguageTo[locale]}</span>
      </a>

      <button
        type="button"
        class="theme-toggle"
        aria-label={ui.header.toggleToDark[locale]}
        data-theme-toggle
        data-label-dark={ui.header.toggleToDark[locale]}
        data-label-light={ui.header.toggleToLight[locale]}
      >
        <Icon name="lucide:sun" class="icon-sun" />
        <Icon name="lucide:moon" class="icon-moon" />
      </button>

      <button
        type="button"
        class="menu-toggle"
        aria-label={ui.header.openMenu[locale]}
        aria-expanded="false"
        aria-controls="mobile-nav"
        data-menu-toggle
        data-label-open={ui.header.openMenu[locale]}
        data-label-close={ui.header.closeMenu[locale]}
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <nav
    id="mobile-nav"
    class="nav-mobile"
    aria-label={ui.header.mobileNav[locale]}
    data-mobile-nav
    inert
  >
    <ul>
      {
        navItems.map((item) => (
          <li>
            <a href={item.href} data-mobile-link>
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script is:inline>
  (function () {
    const root = document.documentElement;
    const toggle = document.querySelector('[data-theme-toggle]');
    function syncToggleLabel() {
      if (!toggle) return;
      const isDark = root.classList.contains('dark');
      const labelDark = toggle.getAttribute('data-label-dark') || 'Switch to dark mode';
      const labelLight = toggle.getAttribute('data-label-light') || 'Switch to light mode';
      toggle.setAttribute('aria-label', isDark ? labelLight : labelDark);
    }
    if (toggle) {
      syncToggleLabel();
      toggle.addEventListener('click', () => {
        const isDark = root.classList.toggle('dark');
        try {
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        } catch (_) {}
        syncToggleLabel();
      });
    }

    const menu = document.querySelector('[data-menu-toggle]');
    const nav = document.querySelector('[data-mobile-nav]');
    const main = document.getElementById('main');
    if (menu && nav) {
      const labelOpen = menu.getAttribute('data-label-open') || 'Open menu';
      const labelClose = menu.getAttribute('data-label-close') || 'Close menu';
      const isOpen = () => menu.classList.contains('open');
      function open() {
        menu.classList.add('open');
        menu.setAttribute('aria-expanded', 'true');
        menu.setAttribute('aria-label', labelClose);
        nav.classList.add('open');
        nav.removeAttribute('inert');
        document.body.style.overflow = 'hidden';
        if (main) main.setAttribute('inert', '');
        nav.querySelector('a')?.focus();
      }
      function close() {
        menu.classList.remove('open');
        menu.setAttribute('aria-expanded', 'false');
        menu.setAttribute('aria-label', labelOpen);
        nav.classList.remove('open');
        document.body.style.overflow = '';
        if (main) main.removeAttribute('inert');
        if (document.activeElement && nav.contains(document.activeElement)) {
          menu.focus();
        }
        nav.setAttribute('inert', '');
      }
      menu.addEventListener('click', (e) => {
        e.stopPropagation();
        isOpen() ? close() : open();
      });
      nav.querySelectorAll('[data-mobile-link]').forEach((a) => {
        a.addEventListener('click', close);
      });
      document.addEventListener('click', (e) => {
        if (!isOpen()) return;
        if (!nav.contains(e.target) && !menu.contains(e.target)) close();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && isOpen()) close();
      });
      const mq = window.matchMedia('(min-width: 768px)');
      mq.addEventListener('change', (e) => {
        if (e.matches && isOpen()) close();
      });
    }

    const header = document.querySelector('.site-header');
    window.addEventListener(
      'scroll',
      () => {
        if (!header) return;
        header.classList.toggle('scrolled', window.scrollY > 8);
      },
      { passive: true },
    );

    const navLinks = document.querySelectorAll(
      '.nav-desktop a[href*="#"], .nav-mobile a[href*="#"]',
    );
    const linkMap = new Map();
    navLinks.forEach((link) => {
      const href = link.getAttribute('href') || '';
      const hashIndex = href.indexOf('#');
      if (hashIndex >= 0 && hashIndex < href.length - 1) {
        const id = href.slice(hashIndex + 1);
        if (!linkMap.has(id)) linkMap.set(id, []);
        linkMap.get(id).push(link);
      }
    });

    if ('IntersectionObserver' in window && linkMap.size > 0) {
      const sections = Array.from(linkMap.keys())
        .map((id) => document.getElementById(id))
        .filter((el) => el !== null);

      function setActive(id) {
        navLinks.forEach((l) => {
          l.classList.remove('active');
          l.removeAttribute('aria-current');
        });
        const links = linkMap.get(id);
        if (links) {
          links.forEach((l) => {
            l.classList.add('active');
            l.setAttribute('aria-current', 'true');
          });
        }
      }

      const sectionIO = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
          if (visible.length > 0) setActive(visible[0].target.id);
        },
        { rootMargin: '-40% 0px -55% 0px', threshold: [0, 0.25, 0.5, 0.75, 1] },
      );
      sections.forEach((s) => sectionIO.observe(s));
    }
  })();
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--bg) 80%, transparent);
    border-bottom: 1px solid transparent;
    transition:
      border-color 0.25s ease,
      background-color 0.25s ease;
  }
  .site-header.scrolled {
    border-bottom-color: var(--border);
    background: color-mix(in srgb, var(--bg) 92%, transparent);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 4rem;
  }
  .brand {
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  .brand:hover :global(.brand-mark) {
    transform: rotate(-6deg) scale(1.05);
  }

  .nav-desktop ul {
    display: none;
    list-style: none;
    gap: 0.25rem;
    margin: 0;
    padding: 0;
  }
  .nav-desktop a {
    display: inline-block;
    padding: 0.5rem 0.85rem;
    border-radius: var(--radius-md);
    color: var(--fg-muted);
    font-size: 0.9rem;
    font-weight: 500;
    transition:
      color 0.2s,
      background-color 0.2s;
  }
  .nav-desktop a:hover {
    color: var(--fg);
    background: var(--bg-elevated);
  }
  .nav-desktop a.active {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }
  .nav-mobile a.active {
    color: var(--accent);
    background: var(--bg-card);
  }

  @media (min-width: 768px) {
    .nav-desktop ul {
      display: flex;
    }
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .theme-toggle,
  .menu-toggle,
  .lang-switch {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.5rem;
    border-radius: var(--radius-md);
    background: transparent;
    border: 1px solid var(--border);
    color: var(--fg);
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease;
  }
  .theme-toggle,
  .menu-toggle {
    width: 2.5rem;
  }
  .lang-switch {
    gap: 0.4rem;
    padding: 0 0.7rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--fg);
  }
  .lang-switch [data-icon] {
    width: 1rem;
    height: 1rem;
  }
  .theme-toggle:hover,
  .menu-toggle:hover,
  .lang-switch:hover {
    background: var(--bg-elevated);
    border-color: var(--border-strong);
  }

  .theme-toggle [data-icon] {
    width: 1.1rem;
    height: 1.1rem;
  }
  .theme-toggle .icon-sun {
    display: none;
  }
  .theme-toggle .icon-moon {
    display: block;
  }
  :global(.dark) .theme-toggle .icon-sun {
    display: block;
  }
  :global(.dark) .theme-toggle .icon-moon {
    display: none;
  }

  .menu-toggle {
    flex-direction: column;
    gap: 4px;
    padding: 0.7rem;
  }
  .menu-toggle span {
    width: 18px;
    height: 2px;
    background: var(--fg);
    border-radius: 2px;
    transition:
      transform 0.25s ease,
      opacity 0.2s ease;
  }
  .menu-toggle.open span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .menu-toggle.open span:nth-child(2) {
    opacity: 0;
  }
  .menu-toggle.open span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  @media (min-width: 768px) {
    .menu-toggle {
      display: none;
    }
  }

  .nav-mobile {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.3s ease;
    background: var(--bg-elevated);
    border-bottom: 1px solid transparent;
  }
  .nav-mobile.open {
    max-height: 24rem;
    border-bottom-color: var(--border);
  }
  .nav-mobile ul {
    list-style: none;
    margin: 0;
    padding: 0.5rem 1.25rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .nav-mobile a {
    display: block;
    padding: 0.75rem 0.5rem;
    color: var(--fg);
    font-weight: 500;
    border-radius: var(--radius-md);
  }
  .nav-mobile a:hover {
    background: var(--bg-card);
  }
  @media (min-width: 768px) {
    .nav-mobile {
      display: none;
    }
  }
</style>
